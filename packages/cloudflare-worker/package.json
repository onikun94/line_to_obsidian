{
  "name": "cloudflare-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/worker.ts --bundle --format=esm --outfile=dist/worker.js --platform=browser",
    "deploy": "pnpm build && wrangler deploy",
    "dev": "pnpm build && wrangler dev",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260625.1",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "0.28.1",
    "happy-dom": "^20.10.6",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
